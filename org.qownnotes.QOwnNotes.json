{
    "app-id": "org.qownnotes.QOwnNotes",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "QOwnNotes",
    "rename-desktop-file": "PBE.QOwnNotes.desktop",
    "rename-icon": "QOwnNotes",
    "finish-args": [
        "--socket=wayland",
        "--socket=fallback-x11",
        "--share=ipc",
        "--share=network",
        "--filesystem=home",
        "--device=dri",
        "--talk-name=org.kde.StatusNotifierWatcher"
    ],
    "modules": [
        {
            "name": "QOwnNotes",
            "buildsystem": "qmake",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/pbek/QOwnNotes/releases/download/v26.7.7/qownnotes-26.7.7.tar.xz",
                    "sha256": "de6fc912b0435d0782bb54a12133c9b5991ffdcd0f2ff46b289b2157f097625b",
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/pbek/QOwnNotes/releases/latest",
                        "version-query": ".tag_name | sub(\"^v\"; \"\")",
                        "url-query": ".assets[] | select(.browser_download_url | capture(\"qownnotes-(?<n>[0-9.]+).tar.xz$\")) | .browser_download_url",
                        "is-main-source": true
                    }
                }
            ]
        },
        {
            "name": "appdata",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm644 org.qownnotes.QOwnNotes.appdata.xml /app/share/appdata/org.qownnotes.QOwnNotes.appdata.xml"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "org.qownnotes.QOwnNotes.appdata.xml"
                }
            ]
        },
        {
            "name": "git",
            "make-args": [
                "INSTALL_SYMLINKS=1",
                "NO_RUST=1"
            ],
            "make-install-args": [
                "INSTALL_SYMLINKS=1",
                "NO_RUST=1"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://mirrors.edge.kernel.org/pub/software/scm/git/git-2.55.0.tar.xz",
                    "sha256": "457fdb04dc8728e007d4688695e6912e6f680727920f2a40bf11eacc17505357",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 5350,
                        "stable-only": true,
                        "url-template": "https://mirrors.edge.kernel.org/pub/software/scm/git/git-$version.tar.xz"
                    }
                }
            ]
        }
    ]
